<div id="hero" class="hero" data-section-id="{{ section.id }}">
  <div class="loading-screen">
    <div class="loading-spinner"></div>
  </div>

  <canvas id="canvas"></canvas>

  <div class="hero-content">
    <div class="glass-overlay">
      <h1>{{ section.settings.title }}</h1>
      <p class="subtitle">{{ section.settings.subtitle }}</p>
      <a href="{{ section.settings.button_link }}" class="cta-button">
        {{ section.settings.button_text }}
      </a>
    </div>
  </div>

  <div class="scroll-hint">↓</div>
</div>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  #canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-content {
    position: absolute;
    z-index: 10;
    text-align: center;
    pointer-events: none;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1.1;
    margin-bottom: 1rem;
    animation: fadeInUp 1s ease-out 0.5s both;
  }

  .subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-secondary);
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: fadeInUp 1s ease-out 0.7s both;
  }

  .cta-button {
    display: inline-block;
    position: relative;
    padding: 18px 50px;
    border: 2px solid var(--color-primary-light);
    background: transparent;
    color: var(--color-primary-light);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-radius: 50px;
    cursor: pointer;
    transition: 0.4s;
    pointer-events: auto;
    overflow: hidden;
    animation: fadeInUp 1s ease-out 0.9s both;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    background: var(--color-primary-light);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
    z-index: -1;
  }

  .cta-button:hover::before {
    width: 300px;
    height: 300px;
  }

  .cta-button:hover {
    color: var(--color-primary-dark);
    transform: scale(1.05);
  }

  .loading-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-primary-dark);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    animation: fadeOut 0.8s ease-out 2s forwards;
  }

  .loading-spinner {
    width: 50px;
    height: 50px;
    border: 2px solid var(--color-text-secondary);
    border-top: 2px solid var(--color-primary-light);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .glass-overlay {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 2rem;
    max-width: 500px;
  }

  .scroll-hint {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.6;
    animation: bounce 2s infinite;
    font-size: 2rem;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; pointer-events: none; }
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-10px); }
  }
</style>

{% schema %}
{
  "name": "Luxury 3D Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Premium 3D Experience"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Crafted for luxury brands"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Luxury 3D Hero"
    }
  ]
}
{% endschema %}
