[
  {
    "name": "Color Scheme",
    "settings": [
      {
        "type": "color",
        "id": "color_primary_dark",
        "label": "Primary Dark",
        "default": "#050505"
      },
      {
        "type": "color",
        "id": "color_primary_light",
        "label": "Primary Light",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent Color",
        "default": "#d4af37"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary Text",
        "default": "#a0a0a0"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "system"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "system"
      }
    ]
  },
  {
    "name": "3D Scene Settings",
    "settings": [
      {
        "type": "range",
        "id": "scene_model_scale",
        "min": 0.5,
        "max": 5,
        "step": 0.1,
        "label": "Model Scale",
        "default": 2
      },
      {
        "type": "range",
        "id": "scene_lighting_intensity",
        "min": 0.5,
        "max": 5,
        "step": 0.1,
        "label": "Lighting Intensity",
        "default": 1.5
      },
      {
        "type": "checkbox",
        "id": "scene_particles_enabled",
        "label": "Enable Particle Effects",
        "default": true
      },
      {
        "type": "range",
        "id": "scene_particle_count",
        "min": 100,
        "max": 1000,
        "step": 50,
        "label": "Particle Count",
        "default": 500
      }
    ]
  },
  {
    "name": "Performance",
    "settings": [
      {
        "type": "select",
        "id": "performance_preset",
        "label": "Performance Preset",
        "options": [
          {
            "value": "low",
            "label": "Low (Mobile)"
          },
          {
            "value": "medium",
            "label": "Medium"
          },
          {
            "value": "high",
            "label": "High (Desktop)"
          }
        ],
        "default": "medium"
      },
      {
        "type": "checkbox",
        "id": "performance_reduce_motion",
        "label": "Respect Reduce Motion Preference",
        "default": true
      }
    ]
  },
  {
    "name": "CDN & Assets",
    "settings": [
      {
        "type": "text",
        "id": "cloudflare_cdn_url",
        "label": "Cloudflare CDN URL (optional)",
        "placeholder": "https://imagedelivery.net/your-account-hash"
      },
      {
        "type": "url",
        "id": "model_asset_url",
        "label": "3D Model Asset URL",
        "placeholder": "/cdn/shop/t/assets/hero.glb"
      }
    ]
  }
]
